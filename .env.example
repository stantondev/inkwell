# ──────────────────────────────────────────────────────────────
# Inkwell Self-Hosted — Environment Variables
# Phase 1 / Alpha
#
# Copy this file: cp .env.example .env
# Then fill in the required values below.
# ──────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────

# Generate with: openssl rand -base64 64
SECRET_KEY_BASE=

# Your domain name (e.g., inkwell.example.com)
DOMAIN=localhost

# Full URLs for your instance
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
API_HOST=localhost

# Database password (used by both db and api containers)
POSTGRES_PASSWORD=inkwell

# ── Email (choose one) ───────────────────────────────────────
# SMTP is recommended for self-hosted instances.
# If both SMTP and Resend are configured, SMTP takes priority.

# Option A: SMTP (recommended)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SSL=false
# Set to "false" to disable SMTP auth (e.g., local Postfix)
# SMTP_AUTH=false

# Option B: Resend API
# RESEND_API_KEY=

# ── Sender ────────────────────────────────────────────────────

# From address for outgoing emails
FROM_EMAIL=Inkwell <noreply@localhost>

# ── Admin ─────────────────────────────────────────────────────

# Comma-separated list of usernames that get admin access
# Create your account first, then add your username here and restart
ADMIN_USERNAMES=

# ── Search (optional) ─────────────────────────────────────────
# Enable Meilisearch for full-text search.
# Start with: docker compose -f docker-compose.selfhosted.yml --profile search up -d

# MEILI_MASTER_KEY=changeme
# MEILI_URL=http://meilisearch:7700

# ── Optional Integrations ────────────────────────────────────

# DeepL API key for content translation (free tier: 500K chars/mo)
# DEEPL_API_KEY=

# Anthropic API key for Muse AI writing prompts
# ANTHROPIC_API_KEY=
# MUSE_ENABLED=false

# Slack webhook for admin notifications
# SLACK_WEBHOOK_URL=

# ── Ports (optional) ─────────────────────────────────────────

# Customize host-side ports if defaults conflict
# API_PORT=4000
# WEB_PORT=3000

# ── Stripe (optional — only if you want billing) ─────────────
# Set INKWELL_SELF_HOSTED=false in docker-compose.selfhosted.yml
# to enable billing with your own Stripe keys.

# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=

# ── Postmark Inbound (optional — for Post by Email) ──────────
# Requires Postmark account + MX record setup

# POSTMARK_INBOUND_TOKEN=
# POST_EMAIL_DOMAIN=post.example.com
